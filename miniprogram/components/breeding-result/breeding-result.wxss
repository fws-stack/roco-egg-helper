.breeding-result {
  margin-top: 24rpx;
}

.br-summary {
  margin-bottom: 20rpx;
}

.br-summary__text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.br-item {
  margin-bottom: 16rpx;
}

.br-item--reverse {
  display: flex;
  align-items: center;
}

.br-parents {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 8rpx;
}

.br-plus {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-light);
  margin: 0 4rpx;
}

.br-item__prob {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  gap: 12rpx;
}

.br-prob-bar {
  flex: 1;
  height: 8rpx;
  background: #EEE;
  border-radius: 4rpx;
  overflow: hidden;
}

.br-prob-bar__fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.br-prob-text {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
  min-width: 50rpx;
  text-align: right;
}

.br-loading {
  text-align: center;
  padding: 40rpx;
}
