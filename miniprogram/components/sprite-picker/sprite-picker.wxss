.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.25s, visibility 0.25s;
}

.picker-overlay--show {
  visibility: visible;
  opacity: 1;
}

.picker-panel {
  background: var(--color-bg);
  border-radius: 32rpx 32rpx 0 0;
  height: 70vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.picker-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.picker-search {
  padding: 0 24rpx 16rpx;
}

.picker-search__input {
  background: var(--color-white);
  border-radius: var(--radius-sm);
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  border: 1rpx solid var(--color-border);
}

.picker-filters {
  white-space: nowrap;
  padding: 0 24rpx 16rpx;
}

.picker-filter__item {
  display: inline-block;
  padding: 8rpx 20rpx;
  margin-right: 12rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: var(--color-white);
  color: var(--color-text-light);
  border: 1rpx solid var(--color-border);
}

.picker-filter__item--active {
  background: var(--color-primary);
  color: var(--color-white);
  border-color: var(--color-primary);
}

.picker-list {
  flex: 1;
  padding: 0 24rpx;
}

/* 隐藏 scroll-view 的滚动条 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}

.picker-list__item {
  margin-bottom: 16rpx;
}
