.entry-list {
  margin-bottom: 32rpx;
}

.entry-card {
  display: flex;
  align-items: center;
  background: var(--color-white);
  border-radius: var(--radius-md);
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
}

.entry-card__icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.entry-card__icon--forward {
  background: #E3F2FD;
}

.entry-card__icon--reverse {
  background: #E8F5E9;
}

.entry-card__icon--egg {
  background: #FFF3E0;
}

.entry-card__icon--pokedex {
  background: #F3E5F5;
}

.entry-card__emoji {
  font-size: 40rpx;
}

.entry-card__content {
  flex: 1;
  min-width: 0;
}

.entry-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 6rpx;
}

.entry-card__desc {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.entry-card__arrow {
  font-size: 36rpx;
  color: var(--color-text-lighter);
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 历史记录 */
.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.history-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.history-item__type {
  width: 80rpx;
  flex-shrink: 0;
}

.history-item__content {
  flex: 1;
  min-width: 0;
}

.history-item__name {
  font-size: 26rpx;
  color: var(--color-text);
}

.history-item__plus {
  margin: 0 8rpx;
  color: var(--color-text-light);
  font-size: 24rpx;
}
