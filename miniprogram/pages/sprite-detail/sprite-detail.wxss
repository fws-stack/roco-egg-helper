.sprite-header__top {
  display: flex;
  align-items: flex-start;
}

.sprite-header__img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--color-bg);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.sprite-header__info {
  flex: 1;
  min-width: 0;
}

.sprite-header__name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
}

.sprite-header__tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sprite-header__rarity {
  color: var(--color-warning);
  font-size: 24rpx;
}

.sprite-header__desc {
  font-size: 26rpx;
  color: var(--color-text-light);
  line-height: 1.5;
}

.sprite-actions {
  padding: 20rpx 24rpx;
}

.detail-breeding__item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.detail-breeding__item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.detail-breeding__link {
  color: var(--color-primary);
}

.detail-breeding__name {
  color: var(--color-text);
}

.detail-breeding__plus {
  margin: 0 6rpx;
  color: var(--color-text-light);
  font-size: 24rpx;
}
