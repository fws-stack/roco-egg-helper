<view class="page-container">
  <!-- 父精灵选择区 -->
  <view class="forward-select">
    <view class="forward-select__item" bindtap="openPicker" data-target="parentA">
      <sprite-card spriteId="{{parentA.id || 0}}" />
    </view>

    <view class="forward-select__plus">
      <text class="text-xlarge text-lighter">+</text>
    </view>

    <view class="forward-select__item" bindtap="openPicker" data-target="parentB">
      <sprite-card spriteId="{{parentB.id || 0}}" />
    </view>
  </view>

  <!-- 已选提示 -->
  <view class="forward-hint" wx:if="{{!parentA || !parentB}}">
    <text class="text-sm text-light">点击上方卡片选择两只父精灵</text>
  </view>

  <!-- 查询结果 -->
  <breeding-result
    wx:if="{{parentA && parentB}}"
    mode="forward"
    results="{{results}}"
    parentAName="{{parentA.name}}"
    parentBName="{{parentB.name}}"
  />

  <!-- 精灵选择器弹窗 -->
  <sprite-picker
    visible="{{pickerVisible}}"
    title="{{pickerTitle}}"
    excludeIds="{{pickerExclude}}"
    bind:select="onPickerSelect"
    bind:close="onPickerClose"
  />
</view>
